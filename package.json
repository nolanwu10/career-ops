{
  "name": "career-ops-monorepo",
  "private": true,
  "workspaces": [
    "apps/desktop",
    "apps/server",
    "apps/web",
    "packages/*",
    "classic"
  ],
  "scripts": {
    "dev:web": "cd apps/web && npm run dev -- --port 3001",
    "dev:server": "node apps/desktop/src/server.js",
    "build:web": "cd apps/web && npm run build",
    "dev:desktop": "npm --prefix apps/desktop run dev",
    "start:desktop": "npm --prefix apps/desktop run start",
    "check:desktop": "npm --prefix apps/desktop run check",
    "test:desktop": "npm --prefix apps/desktop run test",
    "check:server": "npm --prefix apps/server run check",
    "test:server": "npm --prefix apps/server run test",
    "synth:server": "npm --prefix apps/server run synth",
    "bootstrap:server:dev": "npm --prefix apps/server run bootstrap:dev",
    "diff:server:dev": "npm --prefix apps/server run diff:dev",
    "deploy:server:dev": "npm --prefix apps/server run deploy:dev",
    "test:packages": "npm --prefix packages/shared-types run check && npm --prefix packages/shared-types test && npm --prefix packages/job-sources run check && npm --prefix packages/job-sources test",
    "test:classic": "npm --prefix classic run test",
    "verify:classic": "npm --prefix classic run verify",
    "scan:classic": "npm --prefix classic run scan"
  }
}
