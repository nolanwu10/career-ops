{
  "name": "@career-ops/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop and web dashboard for career-ops",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:web": "node src/server.js",
    "dev": "node src/server.js",
    "test": "node --test src/*.test.js ../browser-extension/*.test.js",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/server.js && node --check src/app-core.js && node --check src/cloud-sync.js && node --check src/storage/sqlite-store.js && node --check scripts/import-classic-data.js && node --check src/renderer/renderer.js && node --check src/renderer/web-bridge.js",
    "import:classic": "node scripts/import-classic-data.js",
    "build:win": "electron-builder --win portable",
    "build:win:installer": "electron-builder --win nsis"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "docx-preview": "^0.3.7",
    "dotenv": "^17.0.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jszip": "^3.10.1",
    "js-yaml": "^4.1.1",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.1"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "io.santifer.careerops",
    "productName": "CareerTrack",
    "asar": true,
    "asarUnpack": [
      "node_modules/playwright/**",
      "node_modules/playwright-core/**"
    ],
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "local-data",
        "to": "seed-data",
        "filter": [
          "**/*",
          "!**/*-wal",
          "!**/*-shm"
        ]
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "Career-Ops-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Career-Ops-${version}-${arch}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
