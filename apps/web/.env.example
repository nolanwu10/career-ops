# Cloud API (from CDK output: ApiUrl)
CLOUD_API_URL=https://xxxxxxxx.execute-api.us-east-1.amazonaws.com

# Streaming cover-letter Function URL (from CDK output: CoverLetterStreamUrl)
COVER_LETTER_STREAM_URL=https://xxxxxxxx.lambda-url.us-east-1.on.aws/

# Cognito (from CDK output: CognitoUserPoolId, CognitoClientId, CognitoHostedUiUrl)
COGNITO_DOMAIN=https://career-ops-dev-XXXXXXXXXXXX.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=your-cognito-client-id

# Web app URL (used as OAuth redirect_uri — must be registered in the Cognito app client)
APP_URL=http://localhost:3001

# HTTP port (default 3001)
PORT=3001

# Set to "production" to enable secure cookies
NODE_ENV=development
